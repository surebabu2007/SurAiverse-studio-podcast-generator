# SurAIverse TTS Studio - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp env.template .env
#
# You can also configure API keys via the Settings tab in the web UI.

# ============================================================
# REQUIRED KEYS
# ============================================================

# HuggingFace Access Token (required for model downloads)
# Get your token from: https://huggingface.co/settings/tokens
# 1. Create a free HuggingFace account
# 2. Go to Settings > Access Tokens
# 3. Create a new token with "Read" access
HUGGINGFACE_TOKEN=your_token_here

# Google Gemini API Key (required for podcast generation & Enhance feature)
# Get your key from: https://aistudio.google.com/apikey
# 1. Go to Google AI Studio
# 2. Click "Get API Key"
# 3. Create a new key or use an existing one
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# LLM PROVIDER SETTINGS
# ============================================================

# LLM Provider: "gemini" or "lmstudio" (default: gemini)
# Switch between Google Gemini API and local LM Studio
LLM_PROVIDER=gemini

# LM Studio Configuration (optional, for local LLM support)
# 1. Download and install LM Studio from https://lmstudio.ai
# 2. Load a model and start the local server
# 3. Set the URL below to your LM Studio server address
# No API key needed - LM Studio runs locally
# LM_STUDIO_URL=http://localhost:8000

# ============================================================
# OPTIONAL SETTINGS
# ============================================================

# Default device (auto-detected if not set)
# Options: mps (Mac Apple Silicon), cuda (NVIDIA GPU), cpu
# DEVICE=cuda

# Model cache directory (defaults to ~/.cache/huggingface)
# HF_HOME=/path/to/cache

# Server settings
# GRADIO_SERVER_PORT=7860
# API_SERVER_PORT=8000
